# Copy to .env on the VPS (or set as real environment variables). Never
# commit an actual .env file or real secret values to GitHub.

# ── GitHub webhook auto-deploy (routers/github_webhook.py) ──────────────────
# HMAC secret configured on the GitHub repo webhook (Settings → Webhooks →
# Secret). Must match exactly or every request is rejected with 401.
GITHUB_WEBHOOK_SECRET=
# Absolute path on the VPS to the script that does git pull / install deps /
# restart the service. The webhook handler only invokes it — it does not
# reimplement deploy steps itself.
DEPLOY_SCRIPT_PATH=/root/deploy-aicenter.sh
# Only a push whose ref is refs/heads/<this branch> triggers a deploy.
DEPLOY_BRANCH=main
